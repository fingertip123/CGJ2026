# ===== Godot 引擎生成文件 =====
# 导入缓存（纹理、音频等二进制资源，打开项目时自动重建）
.import/

# 资源导入配置（打开编辑器时会根据源文件重新生成）
*.import

# 导出配置（含本地路径，通常不应共享）
export.cfg
export_presets.cfg

# 导出产物
export/
build/
*.pck
*.zip

# 自动生成的翻译文件
*.translation

# ===== Mono / C#（若启用）=====
.mono/
data_*/
mono_crash.*

# ===== 操作系统 =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ===== 编辑器 / IDE =====
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# Cursor
.cursor/

# ===== 日志与临时文件 =====
*.log
*.tmp
*.bak

# ===== Git 客户端 =====
*.orig
